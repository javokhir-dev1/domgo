# ── PostgreSQL ulanishi ──
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_DATABASE=domgo

# ── Xavfsizlik ──
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Yangi e'lonlar: 1 = darhol tasdiqlanadi, 0 = admin moderatsiyasi
AUTO_APPROVE=1

# Eskiz.uz SMS (bo'sh bo'lsa OTP demo_code sifatida qaytadi)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

UPLOAD_DIR=uploads
